[Unit]
Description=Network connectivity probe with desktop notifications (notify-send / optional dms)
After=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/net-notify run --config %h/.config/net-notify/config.json
Restart=on-failure
RestartSec=10

# Ensure notify-send or dms is on PATH if installed outside standard locations:
# Environment=PATH=/usr/local/bin:/usr/bin
PassEnvironment=DISPLAY WAYLAND_DISPLAY DBUS_SESSION_BUS_ADDRESS XDG_RUNTIME_DIR

[Install]
WantedBy=default.target
